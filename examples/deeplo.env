# Native install env file. Full reference: https://deeplo.xyz/configuration/environment-variables

DEEPLO_DATA_DIR=/var/lib/deeplo
DEEPLO_SSH_PRIVATE_KEY_FILE=/etc/deeplo/keys/deploy_key

DEEPLO_SSH_USER=deploy
# DEEPLO_SSH_PORT=22

# DEEPLO_GITHUB_WEBHOOK_SECRET_FILE=/etc/deeplo/keys/github_webhook_secret
# DEEPLO_GITHUB_TOKEN_FILE=/etc/deeplo/keys/github_token

# DEEPLO_PUBLIC_URL=https://deeplo.example.com
# DEEPLO_LOG_SERVER=true
# DEEPLO_LOG_LEVEL=debug
 
